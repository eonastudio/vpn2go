# === VPN2GO Backend Configuration ===

# Stealthnet API (ваш ТГ-бот панель)
STEALTHNET_BASE_URL=https://your-stealthnet-domain.com/api/v1
STEALTHNET_API_KEY=sk_your_stealthnet_api_key_here

# Remnawave Panel API
REMNAWAVE_BASE_URL=https://your-remnawave-panel.com/api
REMNAWAVE_API_KEY=your_remnawave_api_token_here

# JWT для клиентского токена приложения
JWT_SECRET=change_this_to_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Сервер
HOST=0.0.0.0
PORT=8000
DEBUG=true
